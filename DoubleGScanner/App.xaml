<Application x:Class="DoubleGScanner.App"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 StartupUri="MainWindow.xaml">
 <Application.Resources>
  <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#080A0F"/>
  <SolidColorBrush x:Key="PanelBrush" Color="#10141D"/>
  <SolidColorBrush x:Key="PanelAltBrush" Color="#0C1018"/>
  <SolidColorBrush x:Key="BorderBrush" Color="#222A39"/>
  <SolidColorBrush x:Key="PrimaryBrush" Color="#6574FF"/>
  <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#7885FF"/>
  <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F4F7FF"/>
  <SolidColorBrush x:Key="TextSecondaryBrush" Color="#98A3B8"/>
  <SolidColorBrush x:Key="SuccessBrush" Color="#35D39A"/>
  <SolidColorBrush x:Key="WarningBrush" Color="#FFCA64"/>
  <SolidColorBrush x:Key="DangerBrush" Color="#FF647C"/>
  <Style TargetType="Window">
   <Setter Property="FontFamily" Value="Segoe UI"/>
   <Setter Property="Background" Value="{StaticResource WindowBackgroundBrush}"/>
   <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
  </Style>
  <Style TargetType="Button">
   <Setter Property="Foreground" Value="White"/>
   <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
   <Setter Property="BorderThickness" Value="0"/>
   <Setter Property="FontWeight" Value="SemiBold"/>
   <Setter Property="Padding" Value="20,11"/>
   <Setter Property="Cursor" Value="Hand"/>
   <Setter Property="Template">
    <Setter.Value><ControlTemplate TargetType="Button">
     <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
      <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
     </Border>
     <ControlTemplate.Triggers>
      <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Root" Property="Background" Value="{StaticResource PrimaryHoverBrush}"/></Trigger>
      <Trigger Property="IsEnabled" Value="False"><Setter TargetName="Root" Property="Opacity" Value="0.42"/></Trigger>
     </ControlTemplate.Triggers>
    </ControlTemplate></Setter.Value>
   </Setter>
  </Style>
  <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
   <Setter Property="Background" Value="#1A2130"/>
  </Style>
  <Style TargetType="CheckBox"><Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/></Style>
  <Style TargetType="RadioButton"><Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/></Style>
  <Style TargetType="ProgressBar">
   <Setter Property="Height" Value="7"/><Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
   <Setter Property="Background" Value="#202638"/><Setter Property="BorderThickness" Value="0"/>
  </Style>
  <Style TargetType="DataGrid">
   <Setter Property="Background" Value="{StaticResource PanelAltBrush}"/><Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
   <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/><Setter Property="BorderThickness" Value="1"/>
   <Setter Property="RowBackground" Value="#0D121B"/><Setter Property="AlternatingRowBackground" Value="#101620"/>
   <Setter Property="GridLinesVisibility" Value="Horizontal"/><Setter Property="HorizontalGridLinesBrush" Value="#202737"/>
   <Setter Property="HeadersVisibility" Value="Column"/><Setter Property="CanUserAddRows" Value="False"/>
   <Setter Property="IsReadOnly" Value="True"/><Setter Property="AutoGenerateColumns" Value="False"/>
  </Style>
  <Style TargetType="DataGridColumnHeader">
   <Setter Property="Background" Value="#171D29"/><Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
   <Setter Property="BorderBrush" Value="#252D3D"/><Setter Property="Padding" Value="10,8"/><Setter Property="FontWeight" Value="SemiBold"/>
  </Style>
 </Application.Resources>
</Application>
