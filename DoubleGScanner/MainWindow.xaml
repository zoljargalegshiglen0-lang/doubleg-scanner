<Window x:Class="DoubleGScanner.MainWindow"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 Title="DoubleG Scanner" Width="1180" Height="780" MinWidth="1020" MinHeight="700"
 WindowStartupLocation="CenterScreen">
 <Grid Margin="22">
  <Grid.ColumnDefinitions><ColumnDefinition Width="235"/><ColumnDefinition Width="18"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
  <Border Grid.Column="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="18" Padding="20">
   <Grid>
    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="28"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
    <StackPanel>
     <Border Width="50" Height="50" HorizontalAlignment="Left" Background="#202745" CornerRadius="14">
      <TextBlock Text="DG" Foreground="{StaticResource PrimaryBrush}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
     </Border>
     <TextBlock Text="DOUBLEG" Margin="0,14,0,0" FontSize="22" FontWeight="Bold"/>
     <TextBlock Text="SCANNER" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" FontWeight="SemiBold"/>
    </StackPanel>
    <StackPanel Grid.Row="2">
     <TextBlock Text="SCAN MODE" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,11"/>
     <RadioButton x:Name="QuickMode" Content="Quick scan" IsChecked="True" Margin="0,0,0,10"/>
     <RadioButton x:Name="FullMode" Content="Full scan" Margin="0,0,0,10"/>
     <RadioButton x:Name="ForensicMode" Content="Forensic scan"/>
     <TextBlock Margin="0,13,0,0" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" FontSize="11"
      Text="Full and Forensic modes inspect supported browser records, execution traces, Recycle Bin metadata, and recent executable/archive locations."/>
    </StackPanel>
    <Border Grid.Row="4" Background="#0B1018" BorderBrush="#222B3A" BorderThickness="1" CornerRadius="12" Padding="14">
     <StackPanel>
      <TextBlock Text="PRIVACY-FIRST" Foreground="{StaticResource SuccessBrush}" FontSize="11" FontWeight="Bold"/>
      <TextBlock Margin="0,6,0,0" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" TextWrapping="Wrap"
       Text="Local-only · Read-only&#x0a;No upload · No deletion&#x0a;No passwords or cookies"/>
     </StackPanel>
    </Border>
   </Grid>
  </Border>
  <Grid Grid.Column="2">
   <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="16"/><RowDefinition Height="*"/></Grid.RowDefinitions>
   <Grid>
    <StackPanel>
     <TextBlock Text="CS2 System Integrity Analysis" FontSize="27" FontWeight="Bold"/>
     <TextBlock Margin="0,6,0,0" Foreground="{StaticResource TextSecondaryBrush}" Text="Evidence-based local forensic scan with a professional PDF report."/>
    </StackPanel>
    <Border HorizontalAlignment="Right" VerticalAlignment="Top" Background="#10251E" BorderBrush="#24543F" BorderThickness="1" CornerRadius="10" Padding="11,7">
     <StackPanel Orientation="Horizontal"><Ellipse Width="8" Height="8" Fill="{StaticResource SuccessBrush}" Margin="0,0,8,0"/>
      <TextBlock Text="LOCAL MODE" Foreground="{StaticResource SuccessBrush}" FontSize="11" FontWeight="Bold"/></StackPanel>
    </Border>
   </Grid>
   <Border Grid.Row="2" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="18" Padding="24">
    <Grid>
     <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="18"/><RowDefinition Height="Auto"/><RowDefinition Height="18"/><RowDefinition Height="*"/><RowDefinition Height="18"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
     <Grid>
      <StackPanel>
       <TextBlock x:Name="StatusTitle" Text="Ready to scan" FontSize="22" FontWeight="Bold"/>
       <TextBlock x:Name="StatusDescription" Margin="0,6,0,0" Foreground="{StaticResource TextSecondaryBrush}" Text="Choose a scan mode, accept the privacy notice, and start the analysis."/>
      </StackPanel>
      <Border HorizontalAlignment="Right" Width="90" Height="90" Background="#171D2B" BorderBrush="#2B3550" BorderThickness="1" CornerRadius="45">
       <Grid><Ellipse Width="66" Height="66" Stroke="#2B3550" StrokeThickness="5"/>
        <TextBlock x:Name="ProgressText" Text="0%" FontSize="17" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/></Grid>
      </Border>
     </Grid>
     <ProgressBar Grid.Row="2" x:Name="ScanProgress" Minimum="0" Maximum="100"/>
     <TabControl Grid.Row="4" Background="Transparent" BorderThickness="0">
      <TabItem Header="Overview">
       <Grid Margin="0,16,0,0">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="16"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <UniformGrid Columns="4">
         <Border Margin="0,0,7,0" Background="{StaticResource PanelAltBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="15">
          <StackPanel><TextBlock Text="EVIDENCE" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" FontWeight="Bold"/><TextBlock x:Name="EvidenceCountText" Text="—" Margin="0,7,0,0" FontSize="22" FontWeight="Bold"/></StackPanel>
         </Border>
         <Border Margin="3,0" Background="{StaticResource PanelAltBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="15">
          <StackPanel><TextBlock Text="FINDINGS" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" FontWeight="Bold"/><TextBlock x:Name="FindingCountText" Text="—" Margin="0,7,0,0" FontSize="22" FontWeight="Bold"/></StackPanel>
         </Border>
         <Border Margin="3,0" Background="{StaticResource PanelAltBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="15">
          <StackPanel><TextBlock Text="MODULES" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" FontWeight="Bold"/><TextBlock x:Name="ModuleCountText" Text="—" Margin="0,7,0,0" FontSize="22" FontWeight="Bold"/></StackPanel>
         </Border>
         <Border Margin="7,0,0,0" Background="{StaticResource PanelAltBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="15">
          <StackPanel><TextBlock Text="RISK SCORE" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" FontWeight="Bold"/><TextBlock x:Name="RiskScoreText" Text="—" Margin="0,7,0,0" FontSize="22" FontWeight="Bold"/></StackPanel>
         </Border>
        </UniformGrid>
        <Grid Grid.Row="2">
         <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="310"/></Grid.ColumnDefinitions>
         <Border Background="{StaticResource PanelAltBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="16">
          <StackPanel><TextBlock Text="LIVE SCAN STATUS" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" FontWeight="Bold"/>
           <TextBlock x:Name="LiveModuleText" Text="No scan started" Margin="0,14,0,0" FontWeight="SemiBold"/>
           <TextBlock x:Name="LiveStatusText" Text="The scanner is idle." Margin="0,7,0,0" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
           <TextBlock x:Name="ItemsCheckedText" Text="Items checked: 0" Margin="0,14,0,0" Foreground="{StaticResource TextSecondaryBrush}"/></StackPanel>
         </Border>
         <Border Grid.Column="2" Background="{StaticResource PanelAltBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="16">
          <StackPanel><TextBlock Text="RESULT" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" FontWeight="Bold"/>
           <TextBlock x:Name="VerdictText" Text="NOT SCANNED" Margin="0,13,0,0" FontSize="22" FontWeight="Bold"/>
           <TextBlock x:Name="VerdictDetail" Text="A completed scan is required." Margin="0,8,0,0" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
           <Button x:Name="OpenReportButton" Content="OPEN PDF REPORT" IsEnabled="False" Margin="0,18,0,0" Click="OpenReportButton_Click"/>
           <Button x:Name="OpenFolderButton" Style="{StaticResource SecondaryButton}" Content="OPEN REPORT FOLDER" IsEnabled="False" Margin="0,8,0,0" Click="OpenFolderButton_Click"/></StackPanel>
         </Border>
        </Grid>
       </Grid>
      </TabItem>
      <TabItem Header="Findings">
       <DataGrid x:Name="FindingsGrid" Margin="0,16,0,0" AlternationCount="2">
        <DataGrid.Columns>
         <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="95"/>
         <DataGridTextColumn Header="Score" Binding="{Binding Score}" Width="65"/>
         <DataGridTextColumn Header="Finding" Binding="{Binding Title}" Width="220"/>
         <DataGridTextColumn Header="Source" Binding="{Binding EvidenceSource}" Width="150"/>
         <DataGridTextColumn Header="Artifact" Binding="{Binding Path}" Width="*"/>
        </DataGrid.Columns>
       </DataGrid>
      </TabItem>
      <TabItem Header="Coverage">
       <DataGrid x:Name="CoverageGrid" Margin="0,16,0,0" AlternationCount="2">
        <DataGrid.Columns>
         <DataGridTextColumn Header="Module" Binding="{Binding Module}" Width="190"/>
         <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
         <DataGridTextColumn Header="Checked" Binding="{Binding ItemsChecked}" Width="85"/>
         <DataGridTextColumn Header="Summary" Binding="{Binding Summary}" Width="*"/>
        </DataGrid.Columns>
       </DataGrid>
      </TabItem>
     </TabControl>
     <Grid Grid.Row="6">
      <CheckBox x:Name="ConsentCheckBox" VerticalAlignment="Center"
       Content="I consent to a local read-only system scan and understand that Not detected is not proof of no cheating."
       Checked="ConsentCheckBox_Changed" Unchecked="ConsentCheckBox_Changed"/>
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
       <Button x:Name="CancelButton" Style="{StaticResource SecondaryButton}" Content="CANCEL" IsEnabled="False" Margin="0,0,10,0" Click="CancelButton_Click"/>
       <Button x:Name="StartScanButton" Content="START SCAN" IsEnabled="False" Click="StartScanButton_Click"/>
      </StackPanel>
     </Grid>
    </Grid>
   </Border>
  </Grid>
 </Grid>
</Window>
