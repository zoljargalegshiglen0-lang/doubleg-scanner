<Window x:Class="DoubleGScanner.MainWindow"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 Title="DoubleG Scanner"
 Width="1280" Height="830" MinWidth="1080" MinHeight="720"
 WindowStartupLocation="CenterScreen">
 <Grid>
  <Grid.Background>
   <RadialGradientBrush Center="0.56,0.18" GradientOrigin="0.56,0.18" RadiusX="1.05" RadiusY="1.05">
    <GradientStop Color="#2A0C0E" Offset="0"/>
    <GradientStop Color="#11090A" Offset="0.36"/>
    <GradientStop Color="#070606" Offset="0.72"/>
    <GradientStop Color="#040404" Offset="1"/>
   </RadialGradientBrush>
  </Grid.Background>

  <!-- Ambient red glow, inspired by the DoubleG server identity -->
  <Ellipse Width="520" Height="520" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-290,-180,0" Fill="#4C1619" Opacity="0.30" IsHitTestVisible="False">
   <Ellipse.Effect><BlurEffect Radius="80"/></Ellipse.Effect>
  </Ellipse>
  <Ellipse Width="420" Height="420" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-250,0,0,-260" Fill="#311014" Opacity="0.28" IsHitTestVisible="False">
   <Ellipse.Effect><BlurEffect Radius="76"/></Ellipse.Effect>
  </Ellipse>

  <Grid Margin="20">
   <Grid.ColumnDefinitions><ColumnDefinition Width="258"/><ColumnDefinition Width="20"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>

   <!-- Sidebar -->
   <Border Grid.Column="0" Background="{StaticResource SidebarBrush}" BorderBrush="#3C272A" BorderThickness="1" CornerRadius="24" Padding="20">
    <Border.Effect><DropShadowEffect Color="#000000" BlurRadius="26" ShadowDepth="8" Opacity="0.52"/></Border.Effect>
    <Grid>
     <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="30"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>

     <StackPanel>
      <Grid>
       <Border Width="64" Height="64" HorizontalAlignment="Left" Background="#160D0F" BorderBrush="#5B252A" BorderThickness="1" CornerRadius="18">
        <Border.Effect><DropShadowEffect Color="#7E1218" BlurRadius="18" ShadowDepth="0" Opacity="0.45"/></Border.Effect>
        <Image Source="Assets/DoubleGLogo.png" Width="42" Height="42" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
       </Border>
       <Border HorizontalAlignment="Right" VerticalAlignment="Top" Background="#211315" BorderBrush="#54252A" BorderThickness="1" CornerRadius="10" Padding="9,5">
        <TextBlock Text="v1.3.0" Foreground="#CDBBB7" FontSize="10" FontWeight="SemiBold"/>
       </Border>
      </Grid>
      <TextBlock Text="DOUBLEG" Margin="0,17,0,0" FontSize="24" FontWeight="Bold" Foreground="#F8EFEB"/>
      <TextBlock Text="SECURITY SCANNER" Margin="0,3,0,0" Foreground="#E23A3A" FontSize="11" FontWeight="Bold"/>
      <Border Margin="0,15,0,0" Height="1" Background="#392629"/>
     </StackPanel>

     <StackPanel Grid.Row="2">
      <TextBlock Text="SCAN MODE" Foreground="#9E8C88" FontSize="10" FontWeight="Bold" Margin="2,0,0,11"/>

      <RadioButton x:Name="QuickMode" GroupName="ScanMode" IsChecked="False" Style="{StaticResource ScanModeRadio}">
       <StackPanel>
        <TextBlock Text="Quick scan" FontWeight="SemiBold" FontSize="13"/>
        <TextBlock Text="Adds recent Downloads/Desktop file inspection" Margin="0,3,0,0" Foreground="#907F7C" FontSize="10"/>
       </StackPanel>
      </RadioButton>

      <RadioButton x:Name="FullMode" GroupName="ScanMode" IsChecked="True" Style="{StaticResource ScanModeRadio}">
       <StackPanel>
        <TextBlock Text="Full scan" FontWeight="SemiBold" FontSize="13"/>
        <TextBlock Text="Recommended: files, browser history and Defender scan" Margin="0,3,0,0" Foreground="#907F7C" FontSize="10"/>
       </StackPanel>
      </RadioButton>

      <RadioButton x:Name="ForensicMode" GroupName="ScanMode" Style="{StaticResource ScanModeRadio}">
       <StackPanel>
        <TextBlock Text="Forensic scan" FontWeight="SemiBold" FontSize="13"/>
        <TextBlock Text="Deep scan including Temp, deleted traces and Defender" Margin="0,3,0,0" Foreground="#907F7C" FontSize="10"/>
       </StackPanel>
      </RadioButton>

      <Border Margin="0,7,0,0" Padding="13" Background="#0B090A" BorderBrush="#2E2022" BorderThickness="1" CornerRadius="13">
       <StackPanel>
        <StackPanel Orientation="Horizontal">
         <Ellipse Width="7" Height="7" Fill="#E43B3B" Margin="0,4,8,0" VerticalAlignment="Top"/>
         <TextBlock Text="FORENSIC COVERAGE" Foreground="#C6B4B0" FontSize="10" FontWeight="Bold"/>
        </StackPanel>
        <TextBlock Margin="15,7,0,0" Foreground="#887875" TextWrapping="Wrap" FontSize="10.5"
         Text="Recent downloads, archive payloads, static CS2 indicators, Microsoft Defender no-remediation scans, browser records, execution traces and deleted-file metadata."/>
       </StackPanel>
      </Border>
     </StackPanel>

     <Border Grid.Row="4" Background="#0A0809" BorderBrush="#3B2528" BorderThickness="1" CornerRadius="16" Padding="15">
      <StackPanel>
       <StackPanel Orientation="Horizontal">
        <Image Source="Assets/DoubleGLogo.png" Width="22" Height="22" Stretch="Uniform" Margin="0,0,9,0"/>
        <StackPanel>
         <TextBlock Text="DOUBLEG TEAM" Foreground="#F05A52" FontSize="11" FontWeight="Bold"/>
         <TextBlock Text="MADE BY DOUBLEG" Margin="0,3,0,0" Foreground="#C2B1AD" FontSize="10" FontWeight="SemiBold"/>
        </StackPanel>
       </StackPanel>
       <Border Height="1" Background="#2F2022" Margin="0,12,0,10"/>
       <TextBlock Text="Local-only  •  Read-only  •  No upload" Foreground="#776A67" FontSize="9.5" TextWrapping="Wrap"/>
      </StackPanel>
     </Border>
    </Grid>
   </Border>

   <!-- Main area -->
   <Grid Grid.Column="2">
    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="18"/><RowDefinition Height="*"/></Grid.RowDefinitions>

    <Grid>
     <StackPanel>
      <TextBlock Text="DOUBLEG CS2 SCANNER" FontSize="30" FontWeight="Bold" Foreground="#FAF2EE"/>
      <TextBlock Margin="0,6,0,0" Foreground="#A89692" FontSize="13"
       Text="Advanced system integrity analysis with local forensic reporting."/>
     </StackPanel>
     <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
      <Border Background="#151012" BorderBrush="#39272A" BorderThickness="1" CornerRadius="12" Padding="12,8" Margin="0,0,9,0">
       <StackPanel Orientation="Horizontal">
        <Ellipse Width="7" Height="7" Fill="#E43B3B" Margin="0,0,8,0"/>
        <TextBlock Text="CS2 INTEGRITY" Foreground="#D2C2BE" FontSize="10" FontWeight="Bold"/>
       </StackPanel>
      </Border>
      <Border Background="#0D1A13" BorderBrush="#26533D" BorderThickness="1" CornerRadius="12" Padding="12,8">
       <StackPanel Orientation="Horizontal">
        <Ellipse Width="8" Height="8" Fill="{StaticResource SuccessBrush}" Margin="0,0,8,0"/>
        <TextBlock Text="LOCAL MODE" Foreground="{StaticResource SuccessBrush}" FontSize="10" FontWeight="Bold"/>
       </StackPanel>
      </Border>
     </StackPanel>
    </Grid>

    <Border Grid.Row="2" Background="{StaticResource HeroPanelBrush}" BorderBrush="#43282C" BorderThickness="1" CornerRadius="24" Padding="25">
     <Border.Effect><DropShadowEffect Color="#000000" BlurRadius="30" ShadowDepth="10" Opacity="0.58"/></Border.Effect>
     <Grid>
      <Grid.RowDefinitions>
       <RowDefinition Height="Auto"/><RowDefinition Height="16"/><RowDefinition Height="Auto"/><RowDefinition Height="17"/>
       <RowDefinition Height="*"/><RowDefinition Height="17"/><RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <!-- Scan heading and progress ring -->
      <Grid>
       <StackPanel VerticalAlignment="Center" Margin="0,5,130,0">
        <TextBlock x:Name="StatusTitle" Text="Ready for integrity analysis" FontSize="23" FontWeight="Bold" Foreground="#F8EFEB"/>
        <TextBlock x:Name="StatusDescription" Margin="0,7,0,0" Foreground="#9F8E8B" FontSize="12.5" TextWrapping="Wrap"
         Text="Select a scan profile, confirm consent, and begin the local read-only analysis."/>
       </StackPanel>

       <Grid Width="100" Height="100" HorizontalAlignment="Right">
        <Ellipse Fill="#160F11" Stroke="#45262B" StrokeThickness="1"/>
        <Ellipse Width="78" Height="78" Stroke="#342225" StrokeThickness="6"/>
        <Ellipse Width="78" Height="78" Stroke="#D73538" StrokeThickness="3" StrokeDashArray="2,3" Opacity="0.78">
         <Ellipse.Effect><DropShadowEffect Color="#B51E25" BlurRadius="15" ShadowDepth="0" Opacity="0.60"/></Ellipse.Effect>
        </Ellipse>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
         <TextBlock x:Name="ProgressText" Text="0%" FontSize="19" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#F9F0EC"/>
         <TextBlock Text="SCAN" Margin="0,2,0,0" FontSize="8" FontWeight="Bold" Foreground="#897A77" HorizontalAlignment="Center"/>
        </StackPanel>
       </Grid>
      </Grid>

      <Grid Grid.Row="2">
       <Border Height="7" Background="#2A1B1E" CornerRadius="4"/>
       <ProgressBar x:Name="ScanProgress" Minimum="0" Maximum="100" Value="0"/>
      </Grid>

      <TabControl Grid.Row="4">
       <TabItem Header="Overview">
        <Grid Margin="0,15,0,0">
         <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="14"/><RowDefinition Height="*"/></Grid.RowDefinitions>

         <UniformGrid Columns="4">
          <Border Margin="0,0,7,0" Background="#0C0A0B" BorderBrush="#332326" BorderThickness="1" CornerRadius="15" Padding="16">
           <Grid>
            <Rectangle Height="3" VerticalAlignment="Top" Fill="#D83236" RadiusX="2" RadiusY="2"/>
            <StackPanel Margin="0,14,0,0">
             <TextBlock Text="EVIDENCE" Foreground="#978582" FontSize="9.5" FontWeight="Bold"/>
             <TextBlock x:Name="EvidenceCountText" Text="—" Margin="0,8,0,0" FontSize="25" FontWeight="Bold" Foreground="#F7EDE9"/>
             <TextBlock Text="records analyzed" Margin="0,2,0,0" Foreground="#6F6260" FontSize="9"/>
            </StackPanel>
           </Grid>
          </Border>
          <Border Margin="4,0" Background="#0C0A0B" BorderBrush="#332326" BorderThickness="1" CornerRadius="15" Padding="16">
           <Grid>
            <Rectangle Height="3" VerticalAlignment="Top" Fill="#F04C45" RadiusX="2" RadiusY="2"/>
            <StackPanel Margin="0,14,0,0">
             <TextBlock Text="FINDINGS" Foreground="#978582" FontSize="9.5" FontWeight="Bold"/>
             <TextBlock x:Name="FindingCountText" Text="—" Margin="0,8,0,0" FontSize="25" FontWeight="Bold" Foreground="#F7EDE9"/>
             <TextBlock Text="items requiring review" Margin="0,2,0,0" Foreground="#6F6260" FontSize="9"/>
            </StackPanel>
           </Grid>
          </Border>
          <Border Margin="4,0" Background="#0C0A0B" BorderBrush="#332326" BorderThickness="1" CornerRadius="15" Padding="16">
           <Grid>
            <Rectangle Height="3" VerticalAlignment="Top" Fill="#A7222A" RadiusX="2" RadiusY="2"/>
            <StackPanel Margin="0,14,0,0">
             <TextBlock Text="MODULES" Foreground="#978582" FontSize="9.5" FontWeight="Bold"/>
             <TextBlock x:Name="ModuleCountText" Text="—" Margin="0,8,0,0" FontSize="25" FontWeight="Bold" Foreground="#F7EDE9"/>
             <TextBlock Text="completed collectors" Margin="0,2,0,0" Foreground="#6F6260" FontSize="9"/>
            </StackPanel>
           </Grid>
          </Border>
          <Border Margin="7,0,0,0" Background="#0C0A0B" BorderBrush="#332326" BorderThickness="1" CornerRadius="15" Padding="16">
           <Grid>
            <Rectangle Height="3" VerticalAlignment="Top" Fill="#E06B45" RadiusX="2" RadiusY="2"/>
            <StackPanel Margin="0,14,0,0">
             <TextBlock Text="RISK SCORE" Foreground="#978582" FontSize="9.5" FontWeight="Bold"/>
             <TextBlock x:Name="RiskScoreText" Text="—" Margin="0,8,0,0" FontSize="25" FontWeight="Bold" Foreground="#F7EDE9"/>
             <TextBlock Text="correlated evidence score" Margin="0,2,0,0" Foreground="#6F6260" FontSize="9"/>
            </StackPanel>
           </Grid>
          </Border>
         </UniformGrid>

         <Grid Grid.Row="2">
          <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="15"/><ColumnDefinition Width="330"/></Grid.ColumnDefinitions>

          <Border Background="#0B090A" BorderBrush="#332326" BorderThickness="1" CornerRadius="16" Padding="18">
           <Grid>
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
            <Grid>
             <StackPanel Orientation="Horizontal">
              <Border Width="32" Height="32" Background="#241315" BorderBrush="#57262B" BorderThickness="1" CornerRadius="10">
               <TextBlock Text="●" Foreground="#E33A3E" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <StackPanel Margin="11,0,0,0">
               <TextBlock Text="LIVE SCAN STATUS" Foreground="#C8B5B1" FontSize="10" FontWeight="Bold"/>
               <TextBlock Text="Real-time local collector activity" Margin="0,3,0,0" Foreground="#746663" FontSize="9.5"/>
              </StackPanel>
             </StackPanel>
             <Border HorizontalAlignment="Right" VerticalAlignment="Top" Background="#151012" BorderBrush="#352629" BorderThickness="1" CornerRadius="9" Padding="9,5">
              <TextBlock Text="READ ONLY" Foreground="#9B8985" FontSize="9" FontWeight="Bold"/>
             </Border>
            </Grid>

            <StackPanel Grid.Row="1" Margin="0,21,0,0">
             <TextBlock x:Name="LiveModuleText" Text="No scan started" FontSize="17" FontWeight="SemiBold" Foreground="#F0E5E1"/>
             <TextBlock x:Name="LiveStatusText" Text="DoubleG Scanner is standing by." Margin="0,8,0,0" Foreground="#958582" FontSize="12" TextWrapping="Wrap"/>
            </StackPanel>

            <Border Grid.Row="2" Margin="0,18,0,0" Background="#130E10" BorderBrush="#2F2123" BorderThickness="1" CornerRadius="11" Padding="11,9">
             <TextBlock x:Name="ItemsCheckedText" Text="Items checked: 0" Foreground="#C4B2AE" FontSize="11"/>
            </Border>
           </Grid>
          </Border>

          <Border Grid.Column="2" Background="#0B090A" BorderBrush="#3A2529" BorderThickness="1" CornerRadius="16" Padding="18">
           <StackPanel>
            <StackPanel Orientation="Horizontal">
             <Ellipse Width="8" Height="8" Fill="#D83236" Margin="0,3,8,0" VerticalAlignment="Top"/>
             <TextBlock Text="ANALYSIS RESULT" Foreground="#C8B5B1" FontSize="10" FontWeight="Bold"/>
            </StackPanel>
            <TextBlock x:Name="VerdictText" Text="NOT SCANNED" Margin="0,18,0,0" FontSize="25" FontWeight="Bold" Foreground="#F7EDE9"/>
            <TextBlock x:Name="VerdictDetail" Text="A completed scan is required before a result can be issued." Margin="0,8,0,0" Foreground="#948481" FontSize="11.5" TextWrapping="Wrap" MinHeight="46"/>
            <Border Height="1" Background="#312124" Margin="0,16,0,14"/>
            <Button x:Name="OpenReportButton" Style="{StaticResource PrimaryButton}" Content="OPEN PDF REPORT" IsEnabled="False" Click="OpenReportButton_Click"/>
            <Button x:Name="OpenFolderButton" Style="{StaticResource SecondaryButton}" Content="OPEN REPORT FOLDER" IsEnabled="False" Margin="0,9,0,0" Click="OpenFolderButton_Click"/>
           </StackPanel>
          </Border>
         </Grid>
        </Grid>
       </TabItem>

       <TabItem Header="Findings">
        <DataGrid x:Name="FindingsGrid" Margin="0,15,0,0" AlternationCount="2">
         <DataGrid.Columns>
          <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="95"/>
          <DataGridTextColumn Header="Score" Binding="{Binding Score}" Width="65"/>
          <DataGridTextColumn Header="Finding" Binding="{Binding Title}" Width="230"/>
          <DataGridTextColumn Header="Source" Binding="{Binding EvidenceSource}" Width="155"/>
          <DataGridTextColumn Header="Artifact" Binding="{Binding Path}" Width="*"/>
         </DataGrid.Columns>
        </DataGrid>
       </TabItem>

       <TabItem Header="Coverage">
        <DataGrid x:Name="CoverageGrid" Margin="0,15,0,0" AlternationCount="2">
         <DataGrid.Columns>
          <DataGridTextColumn Header="Module" Binding="{Binding Module}" Width="200"/>
          <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="105"/>
          <DataGridTextColumn Header="Checked" Binding="{Binding ItemsChecked}" Width="90"/>
          <DataGridTextColumn Header="Summary" Binding="{Binding Summary}" Width="*"/>
         </DataGrid.Columns>
        </DataGrid>
       </TabItem>
      </TabControl>

      <!-- Consent and actions -->
      <Grid Grid.Row="6">
       <CheckBox x:Name="ConsentCheckBox" Style="{StaticResource ConsentCheck}" VerticalAlignment="Center"
        Checked="ConsentCheckBox_Changed" Unchecked="ConsentCheckBox_Changed">
        <TextBlock TextWrapping="Wrap" Width="620" Foreground="#A49390" FontSize="10.5"
         Text="I consent to a local read-only system scan and understand that “Not detected” is not proof that cheating never occurred."/>
       </CheckBox>
       <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
        <Button x:Name="CancelButton" Style="{StaticResource GhostButton}" Content="CANCEL" IsEnabled="False" Width="100" Margin="0,0,10,0" Click="CancelButton_Click"/>
        <Button x:Name="StartScanButton" Style="{StaticResource PrimaryButton}" Content="START SCAN" IsEnabled="False" Width="150" Click="StartScanButton_Click"/>
       </StackPanel>
      </Grid>
     </Grid>
    </Border>
   </Grid>
  </Grid>
 </Grid>
</Window>
