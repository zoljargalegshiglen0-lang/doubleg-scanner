{
  "product": "DoubleG Scanner",
  "version": "1.11.0",
  "network_upload": false,
  "telemetry": false,
  "background_service": false,
  "startup_persistence": false,
  "kernel_driver": false,
  "file_delete_or_quarantine": false,
  "password_cookie_session_collection": false,
  "private_document_content_collection": false,
  "writes": [
    "Documents/DoubleG Scanner/Reports",
    "scanner-owned temporary browser database copies removed after scan"
  ],
  "reads": [
    "Windows security profile and scanner hash",
    "process/module metadata",
    "file hash/signature status",
    "supported browser relevant visit/download metadata",
    "Prefetch/UserAssist/BAM/Recent Items",
    "Recycle Bin metadata",
    "registered driver and Run/RunOnce/Startup metadata",
    "live TCP table and network-interface counters",
    "recent executable/archive metadata in Downloads/Desktop/Temp",
    "ZIP/JAR entry names and limited embedded executable bytes for static indicators",
    "Microsoft Defender custom-scan command output with remediation disabled"
  ],
  "microsoft_defender_disable_remediation": true,
  "automatic_remediation": false,
  "forensic_scope": {
    "ntfs_mft": "read-only metadata enumeration",
    "usn_journal": "read-only recent change/deletion events",
    "unallocated_space": "capped executable/archive signature sampling only",
    "restores_files_to_disk": false,
    "scans_personal_photos_or_documents": false
  },
  "quick_deleted_trace_scope": {
    "browser_download_records": true,
    "missing_downloaded_files": true,
    "recycle_bin_metadata": true,
    "usn_deletion_events_when_elevated": true,
    "raw_unallocated_recovery": false,
    "classification_note": "Generic deleted executables are review evidence, not confirmed cheats."
  },
  "kernel_integrity_scope": {
    "custom_kernel_driver_installed": false,
    "kernel_memory_modified": false,
    "loaded_driver_enumeration": true,
    "driver_hash_and_signature": true,
    "code_integrity_events": true,
    "driver_service_install_events": true,
    "vbs_and_memory_integrity_status": true,
    "dma_protection_capability": true,
    "vulnerable_driver_blocklist_configuration": true,
    "exact_vulnerable_driver_hash_dataset_supported": true,
    "filename_heuristics_are_conclusive": false
  },
  "scan_tier_map": {
    "quick": {
      "scope": "Previous Full Scan",
      "includes": [
        "system and processes",
        "CS2 modules",
        "browser history and downloads",
        "execution history",
        "Recycle Bin metadata",
        "driver/startup persistence",
        "network activity",
        "120-day recursive Downloads/Desktop/Temp file scan",
        "Microsoft Defender Downloads/Desktop scan"
      ],
      "kernel_driver_integrity": false,
      "raw_ntfs_disk_forensics": false
    },
    "full": {
      "scope": "Previous Forensic Scan",
      "includes": [
        "all Quick modules",
        "365-day deeper local artifacts",
        "NTFS MFT metadata",
        "USN Journal",
        "unallocated executable/archive signature sampling",
        "Microsoft Defender Temp scan"
      ],
      "requires_administrator": true,
      "kernel_driver_integrity": false
    },
    "forensic": {
      "scope": "Full disk forensics plus Kernel & Driver Integrity",
      "includes": [
        "all Full modules",
        "loaded kernel driver enumeration",
        "driver signature and SHA-256",
        "VBS/HVCI/DMA security posture",
        "Code Integrity events",
        "driver-service installation events",
        "kernel driver correlation"
      ],
      "requires_administrator": true,
      "kernel_driver_integrity": true
    }
  }
}